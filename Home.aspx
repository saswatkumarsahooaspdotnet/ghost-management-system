<script>
    document.addEventListener("DOMContentLoaded", function () {
        const states = document.querySelectorAll('.states-group path');
        const display = document.getElementById('state-info');

        states.forEach(state => {
            state.addEventListener('click', function (e) {
                e.preventDefault();

                states.forEach(s => s.classList.remove('state-selected'));
                this.classList.add('state-selected');

                const stateName = this.getAttribute('title') || this.getAttribute('data-name');

                if (display) {
                    display.innerHTML = `<i class="fas fa-ghost me-2"></i> Current Territory: <span class="text-white">${stateName}</span>`;
                }

                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        title: 'Ghost Surveillance: ' + stateName,
                        text: 'Accessing encrypted dossiers for ' + stateName + '...',
                        icon: 'info',
                        background: '#1a1d20',
                        color: '#0dcaf0',
                        showConfirmButton: false,
                        timer: 2000,
                        timerProgressBar: true,
                        willClose: () => {
                            redirectToCards(stateName);
                        }
                    });
                } else {
                    redirectToCards(stateName);
                }
            });
        });

        function redirectToCards(name) {
            window.location.href = "CardPagePerState.aspx?state=" + encodeURIComponent(name);
        }
    });
</script>
</asp:Content>

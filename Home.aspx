<%@ Page Title="" Language="C#" MasterPageFile="~/MasterPage.Master" AutoEventWireup="true" CodeBehind="Home.aspx.cs" Inherits="ghost_series.Home" %>

<asp:Content ID="Content1" ContentPlaceHolderID="head" runat="server">
    <style>
        .animated-welcome {
            font-weight: bold;
            text-align: center;
            text-decoration: dotted;
            /* Animation Name | Duration | Timing | Iteration */
            animation: ghostStyleChange 10s infinite;
        }

        @keyframes ghostStyleChange {
            0%, 20% {
                color: cadetblue;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }

            21%, 40% {
                color: #0dcaf0; /* Cyan */
                font-family: 'Courier New', Courier, monospace;
                text-shadow: 0 0 10px #0dcaf0;
            }

            41%, 60% {
                color: #ff00ff; /* Magenta */
                font-family: 'Georgia', serif;
            }

            61%, 80% {
                color: #7ef9ff; /* Electric Blue */
                font-family: 'Impact', Charcoal, sans-serif;
                letter-spacing: 2px;
            }

            81%, 100% {
                color: #ffffff; /* White Glow */
                font-family: 'Comic Sans MS', cursive;
                text-shadow: 2px 2px 5px #0dcaf0;
            }
        }
        /* ... existing animated-welcome styles ... */
        /* Force the container to take full width and center its children */
        .map-main-container {
            display: flex !important;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100% !important;
            min-height: 90vh; /* Takes up most of the vertical space */
            margin: 0 auto;
            padding: 40px 0;
        }

        /* Ensure the section is also centered */
        .map-section {
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* The Glass Box styling with centering */
        .map-glass {
            background: rgba(33, 37, 41, 0.85);
            backdrop-filter: blur(10px);
            border: 2px solid rgba(13, 202, 240, 0.3);
            border-radius: 30px;
            padding: 30px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.7);

            width: 98%;              /* almost full width */
            max-width: 1100px;       /* increased from 800px */
            margin: 0 auto;

            display: flex;
            justify-content: center;
            align-items: center;
        }


        /* Make sure the SVG scales inside the glass box */
        #india-svg-map {
            width: 100%;
            height: auto;
            max-height: 85vh;
        }

        .map-main-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 80vh;
            padding: 20px;
        }




        .state {
            fill: #2c3e50; /* Deep slate color */
            stroke: #0dcaf0; /* Cyan outline */
            stroke-width: 0.8;
            transition: all 0.4s ease;
            cursor: pointer;
        }

            .state:hover {
                fill: #0dcaf0 !important;
                filter: drop-shadow(0 0 15px #0dcaf0);
                transform: scale(1.01); /* Subtle zoom */
            }

        .state-selected {
            fill: #ff00ff !important; /* Magenta highlight */
            stroke: #ffffff !important;
            stroke-width: 1.5;
            filter: drop-shadow(0 0 20px #ff00ff);
        }

        /* Section Header Styling */
        .map-section h2 {
            color: #0dcaf0;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 4px;
            margin-bottom: 10px;
            text-shadow: 0 0 10px rgba(13, 202, 240, 0.5);
        }

        .map-subtitle {
            color: #0dcaf0;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 4px;
            margin-bottom: 10px;
            text-shadow: 0 0 10px rgba(13, 202, 240, 0.5);
            font-size: 1.1rem;
        }

        /* Mobile Adjustments */
        @media (max-width: 768px) {
            .map-glass {
                padding: 15px;
                border-radius: 15px;
            }

            .map-section h2 {
                font-size: 1.5rem;
                letter-spacing: 2px;
            }
        }
    </style>


</asp:Content>
